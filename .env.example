# Gemini API Key (required)
# Get from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=

# ElevenLabs API Key (for TTS with lip-sync)
# Get from: https://elevenlabs.io > Profile > API Keys
VITE_ELEVENLABS_API_KEY=

# Ojin API Key (for avatar)
# Get from: https://ojin.ai
VITE_ODJIN_API_KEY=

# Ojin Config ID (your custom avatar)
# Get from your Ojin dashboard
VITE_ODJIN_CONFIG_ID=

# Custom AI personality (optional)
VITE_SYSTEM_PROMPT="You are my personal assistant. You are helpful, polite, and assist me with my daily tasks."
